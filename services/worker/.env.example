# Milvus
MILVUS_ADDRESS=your-cluster.zillizcloud.com:19530
MILVUS_TOKEN=your_api_key_or_user:password
MILVUS_COLLECTION=your_collection_name

# PostgreSQL (Railway auto-injects DATABASE_URL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/railway

# Google Vertex AI
VERTEX_AI_PROJECT_ID=your_gcp_project_id
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Worker tuning (optional, defaults shown)
CONCURRENCY=5
TARGET_KOL_COUNT=10000
MILVUS_PAGE_SIZE=500
MILVUS_TIMEOUT=30000
MILVUS_RETRIES=2
MILVUS_RETRY_DELAY=1000
IMAGE_TIMEOUT_MS=3000
AI_MAX_RETRIES=2
LOG_LEVEL=info
